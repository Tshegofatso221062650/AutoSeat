# Supabase Configuration
# ────────────────────────────────────────────────────────────────
# To enable Supabase integration, add these environment variables:
#
# 1. Create a .env.local file in the project root (same level as package.json)
# 2. Copy the values below and add your actual Supabase credentials
# 3. Restart the development server
#
# Without these variables, the application will automatically use
# mock data from src/data/mockData.js as a fallback.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-publishable-key

# ────────────────────────────────────────────────────────────────
# How to get your credentials:
# 1. Go to https://supabase.com
# 2. Create a new project or use an existing one
# 3. Go to Project Settings > API
# 4. Copy the "Project URL" → VITE_SUPABASE_URL
# 5. Copy the "anon/public" key → VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY
# 6. Paste them into .env.local
# ────────────────────────────────────────────────────────────────
